# Copy this file to android/key.properties only in a controlled build
# environment. It is intentionally ignored by Git; never commit a keystore,
# its passwords, or an exported signing key.
#
# Preferred flow: run ./scripts/generate-release-signing-keys.sh from the
# repository root. That writes secrets/signing/android/ and copies this file
# into place with paths relative to apps/ros/android/.
storeFile=../../../secrets/signing/android/ros-release.p12
storePassword=replace-in-controlled-build-environment
keyAlias=gotigin-restaurant-os
keyPassword=replace-in-controlled-build-environment
