# Professional API local/staging environment template.
# Copy to .env (gitignored) and fill non-secret development values only.
# Never commit real credentials.

ROS_LISTEN_ADDRESS=127.0.0.1:3000
ROS_DEPLOYMENT_ENVIRONMENT=development

# Required only when Professional sync is enabled.
# ROS_DATABASE_URL=postgresql://ros_api:CHANGEME@127.0.0.1:5432/restaurant_os?sslmode=disable
# ROS_SYNC_TOKEN_PUBLIC_KEY_FILE=./secrets/device-token-public.pem
# ROS_SYNC_TOKEN_ISSUER=https://identity.staging.ros.gotigin.com
# ROS_SYNC_TOKEN_AUDIENCE=restaurant-os-professional-api
# ROS_SYNC_REQUESTS_PER_MINUTE=120

# Operational bounds
# ROS_API_REQUEST_TIMEOUT_MS=15000
# ROS_API_QUEUE_TIMEOUT_MS=100
# ROS_API_MAX_IN_FLIGHT=256
